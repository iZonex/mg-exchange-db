# ExchangeDB SQL Logic Test - Basic Suite
# Tests CREATE TABLE, INSERT, SELECT, aggregations, filtering, ordering.

# ============================================================
# Schema setup
# ============================================================

statement ok
CREATE TABLE trades (timestamp TIMESTAMP, symbol VARCHAR, price DOUBLE, volume DOUBLE, side VARCHAR)

statement ok
CREATE TABLE metrics (timestamp TIMESTAMP, host VARCHAR, cpu DOUBLE, mem DOUBLE)

